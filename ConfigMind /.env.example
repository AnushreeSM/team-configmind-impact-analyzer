# ── Lytx environment ──────────────────────────────────────────────────────────
LYTX_ENV=dev

# ── AWS Bedrock ────────────────────────────────────────────────────────────────
BEDROCK_REGION=us-west-2
# Use the cross-region inference profile ID for Claude claude-sonnet-4-6
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ── Service base URLs (auto-derived from LYTX_ENV if not set) ─────────────────
GROUP_API_URL=https://cloud-lytx-group-api-dev.aws.drivecaminc.xyz
DEVICE_SETTINGS_URL=https://cloud-lytx-devicesettings-api-dev.aws.drivecaminc.xyz
GROUP_OPTION_URL=https://cloud-lytx-aws-groupoption-service-dev.aws.drivecaminc.xyz
WORKFLOW_URL=https://cloud-lytx-safety-workflow-admin-api-dev.aws.drivecaminc.xyz
PERMISSIONS_URL=https://cloud-lytx-core-permissions-service-dev.aws.drivecaminc.xyz
USERS_URL=https://cloud-lytx-users-api-dev.aws.drivecaminc.xyz
FEATURE_TOGGLE_URL=https://cloud-lytx-featuretoggle-handler-dev.aws.drivecaminc.xyz

# ── Real endpoints confirmed by user (hardcoded defaults, override if env changes) ──
USERS_SEARCH_URL=https://drivecam-int2.drivecaminc.xyz/api/v1/core/users/memberships/search
VEHICLES_SEARCH_URL=https://api-dev.aws.drivecaminc.xyz/public/admin-vehicle/vehicles/search
DEVICES_SEARCH_URL=https://api-dev.aws.drivecaminc.xyz/api/devicelist/devices
EVENTS_SEARCH_URL=https://api-dev.aws.drivecaminc.xyz/api/safetyevents/events/v2

# ── PCS Feature Configs ────────────────────────────────────────────────────────
PCS_CONFIGS_PATH=c:\Repo\ProgramConfig\programconfiguration-service\src\Lytx.ProgramConfiguration.Service\Configurations\Features

# ── HTTP ──────────────────────────────────────────────────────────────────────
HTTP_TIMEOUT=15.0
